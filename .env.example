PORT=3000
PUBLIC_BASE_URL=https://app.imanglar.com

# ── Meta Webhooks ───────────────────────────────────────────────────────────
META_VERIFY_TOKEN=change_this_verify_token
GRAPH_API_VERSION=v22.0

# Activar envío real de mensajes Meta (por defecto está en modo mock)
META_LIVE_MODE=false

# WhatsApp Business Cloud API
META_ACCESS_TOKEN=replace_with_whatsapp_or_page_access_token
META_PHONE_NUMBER_ID=replace_with_phone_number_id

# Facebook / Messenger / Instagram (compatibilidad con server legacy)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
PAGE_ACCESS_TOKEN=
PAGE_ID=

# ── IA Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Base de datos (futura) ──────────────────────────────────────────────────
DATABASE_URL=

# ── Acceso privado a plataforma ─────────────────────────────────────────────
PLATFORM_PASSWORD=change_this_private_password

# ── Debug ───────────────────────────────────────────────────────────────────
DEBUG=
