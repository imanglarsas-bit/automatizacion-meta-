PORT=3000
PUBLIC_BASE_URL=https://app.imanglar.com

# ── Meta Webhooks ───────────────────────────────────────────────────────────
META_VERIFY_TOKEN=change_this_verify_token
GRAPH_API_VERSION=v22.0

# Activar envío real de mensajes Meta (por defecto está en modo mock)
META_LIVE_MODE=false

# WhatsApp Business Cloud API
# Recomendado: usa estas dos variables para el número principal de Manglar.
META_ACCESS_TOKEN=replace_with_whatsapp_or_page_access_token
META_PHONE_NUMBER_ID=replace_with_phone_number_id

# Facebook / Messenger / Instagram (compatibilidad; puedes repetir los mismos valores)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
PAGE_ACCESS_TOKEN=
PAGE_ID=

# ── IA Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Base de datos (futura) ──────────────────────────────────────────────────
DATABASE_URL=

# Carpeta persistente para perfiles, usuarios, entrenamiento y métricas.
# En Render debe apuntar al mount path del Persistent Disk, por ejemplo /var/data.
DATA_DIR=

# ── Acceso privado a plataforma ─────────────────────────────────────────────
# Usuarios cliente temporales: backend/data/client-users.mock.json
ADMIN_PASSWORD=change_this_admin_password

# ── Debug ───────────────────────────────────────────────────────────────────
DEBUG=
